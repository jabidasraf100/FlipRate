<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@color/bg"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/wishlist_amount_line"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="100.00 USD → EUR"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/wishlist_remove_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="Remove wishlist entry"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <TextView
        android:id="@+id/wishlist_rate_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Current rate: —"
        android:textColor="@color/text_muted"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/wishlist_total_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: —"
        android:textColor="@color/text"
        android:textSize="13sp" />

</LinearLayout>
